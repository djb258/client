{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "meta": {
    "name": "IMO_CONTROL",
    "version": "3.4.1",
    "created": "2026-01-30",
    "last_modified": "2026-02-25",
    "authority": "imo-creator",
    "status": "ACTIVE",
    "description": "Child repo governance contract for Client Intake & Vendor Export System",
    "constitution_file": "CONSTITUTION.md"
  },

  "control_plane": {
    "control_version": "3.4.1",
    "upstream_repo": "imo-creator",
    "upstream_commit": "56943d4",
    "drift_detection": {
      "enabled": true,
      "warn_on_outdated": true,
      "check_frequency": "on_audit"
    }
  },

  "governance": {
    "sovereign": "imo-creator",
    "sovereignty_type": "INHERITED",
    "conformance_direction": "UPSTREAM",
    "interpretation_allowed": false,
    "modification_requires": ["ADR", "HUMAN_APPROVAL"]
  },

  "identity": {
    "repo_name": "client",
    "hub_id": "client-subhive",
    "sovereign_reference": "imo-creator",
    "domain_spec": "doctrine/REPO_DOMAIN_SPEC.md",
    "osam": "doctrine/OSAM.md",
    "schema": "clnt",
    "spine_table": "clnt.client",
    "universal_join_key": "client_id"
  },

  "lifecycle": {
    "current_phase": "documentation_enforcement",
    "allowed_phases": [
      "constitutional_admission",
      "structural_instantiation",
      "data_declaration",
      "execution_wiring",
      "dba_enforcement",
      "documentation_enforcement",
      "hygiene_audit",
      "cleanup_execution"
    ]
  },

  "structure": {
    "model": "HUB_SUBHUB_ALTITUDE",
    "hub": {
      "definition": "Repository root = Hub",
      "required_files": [
        "REGISTRY.yaml",
        "DOCTRINE.md",
        "README.md",
        "heir.doctrine.yaml"
      ]
    },
    "altitude": {
      "branches": ["sys", "data", "app", "ai", "ui"],
      "path_pattern": "src/{sys,data,app,ai,ui}/",
      "enforcement": "MANDATORY"
    }
  },

  "schema": {
    "name": "clnt",
    "database": "Neon PostgreSQL",
    "total_tables": 16,
    "total_views": 0,
    "spokes": {
      "S1": {"name": "Hub", "tables": ["client", "client_error"]},
      "S2": {"name": "Plan", "tables": ["plan", "plan_error", "plan_quote"]},
      "S3": {"name": "Employee", "tables": ["person", "employee_error", "election", "enrollment_intake", "intake_record"]},
      "S4": {"name": "Vendor", "tables": ["vendor", "vendor_error", "external_identity_map", "invoice"]},
      "S5": {"name": "Service", "tables": ["service_request", "service_error"]}
    },
    "enforcement": {
      "registry_first": true,
      "column_registry": "src/data/db/registry/clnt_column_registry.yml",
      "codegen_script": "scripts/codegen-schema.ts",
      "enforcement_scripts": [
        "scripts/ctb-registry-gate.sh",
        "scripts/ctb-drift-audit.sh",
        "scripts/detect-banned-db-clients.sh",
        "scripts/verify-governance-ci.sh",
        "scripts/bootstrap-audit.sh"
      ],
      "new_doctrine": [
        "templates/doctrine/CTB_REGISTRY_ENFORCEMENT.md",
        "templates/doctrine/EXECUTION_SURFACE_LAW.md",
        "templates/doctrine/FAIL_CLOSED_CI_CONTRACT.md",
        "templates/doctrine/LEGACY_COLLAPSE_PLAYBOOK.md"
      ]
    }
  },

  "forbidden": {
    "folders": ["utils", "helpers", "common", "shared", "lib", "misc"]
  },

  "claude_code_behavior": {
    "must": [
      "Check IMO_CONTROL.json exists before any work",
      "Read doctrine/REPO_DOMAIN_SPEC.md for domain bindings",
      "Read doctrine/OSAM.md for query routing contracts",
      "Enforce CTB altitude structure",
      "Refuse to modify parent doctrine",
      "Route all queries through OSAM-declared paths",
      "HALT on undeclared join attempts",
      "Enforce registry-first principle (register before create)",
      "Enforce OWN-10a/10b cardinality (1 CANONICAL + 1 ERROR per spoke)",
      "Enforce Execution Surface Law (code only in CTB branches)",
      "Enforce fail-closed CI posture (no continue-on-error)"
    ],
    "must_not": [
      "Modify parent doctrine files",
      "Skip descent gates",
      "Invent structure beyond doctrine",
      "Query STAGING tables as business surfaces",
      "Query AUDIT tables as business surfaces",
      "Create joins not declared in OSAM",
      "Use banned DB clients (direct pg/mysql imports outside gatekeeper)",
      "Place executable code outside CTB branches",
      "Use continue-on-error in CI enforcement jobs",
      "Connect to database as superuser (use ctb_app_role)"
    ]
  }
}
