{
  "name": "client-hub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "d1:migrate:local": "wrangler d1 execute client-hub --local --file=migrations/0001_create_tables.sql",
    "d1:migrate:remote": "wrangler d1 execute client-hub --remote --file=migrations/0001_create_tables.sql"
  },
  "dependencies": {
    "hono": "^4.7.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.11.1"
  }
}
