{
  "mcpServers": {
    "github": {
      "command": "node",
      "args": ["./mcp-servers/github-composio-server.js"],
      "env": {
        "COMPOSIO_API_KEY": "DOPPLER:COMPOSIO_API_KEY",
        "COMPOSIO_BASE_URL": "https://backend.composio.dev"
      },
      "description": "GitHub integration through Composio for repository management and automation"
    },
    "smartsheet": {
      "command": "node",
      "args": ["./mcp-servers/smartsheet-server.js"],
      "env": {
        "SMARTSHEET_API_TOKEN": "DOPPLER:SMARTSHEET_API_TOKEN",
        "SMARTSHEET_BASE_URL": "https://api.smartsheet.com/2.0"
      },
      "description": "Smartsheet integration for managing sheets, rows, and columns"
    },
    "composio": {
      "command": "node",
      "args": ["./mcp-servers/composio-server.js"],
      "env": {
        "COMPOSIO_API_KEY": "DOPPLER:COMPOSIO_API_KEY",
        "COMPOSIO_BASE_URL": "https://backend.composio.dev"
      },
      "description": "Composio integration for AI tool orchestration"
    },
    "instantly": {
      "command": "node",
      "args": ["./mcp-servers/instantly-server.js"],
      "env": {
        "INSTANTLY_API_KEY": "DOPPLER:INSTANTLY_API_KEY",
        "INSTANTLY_BASE_URL": "https://api.instantly.ai"
      },
      "description": "Instantly.ai integration for email outreach campaigns"
    },
    "heyreach": {
      "command": "node",
      "args": ["./mcp-servers/heyreach-server.js"],
      "env": {
        "HEYREACH_API_KEY": "DOPPLER:HEYREACH_API_KEY"
      },
      "description": "HeyReach integration for LinkedIn outreach automation"
    }
  },
  "serverConfig": {
    "timeout": 30000,
    "retries": 3,
    "logLevel": "info",
    "healthCheck": {
      "enabled": true,
      "interval": "30s"
    }
  }
}
